RewriteEngine On

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Force www
RewriteCond %{HTTP_HOST} !^www\. [NC]
RewriteRule ^(.*)$ https://www.%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# 301 redirects - old Fasthosts builder URLs
RewriteRule ^landscaping$ https://www.roundwoodsolutions.co.uk/commercial-landscaping-kent [R=301,L]
RewriteRule ^learning-and-play$ https://www.roundwoodsolutions.co.uk/school-grounds-playground-services [R=301,L]
RewriteRule ^grounds-maintenance$ https://www.roundwoodsolutions.co.uk/grounds-maintenance-kent-commercial-property-maintenance [R=301,L]
RewriteRule ^contact$ https://www.roundwoodsolutions.co.uk/contact-us [R=301,L]
RewriteRule ^about$ https://www.roundwoodsolutions.co.uk/about-us [R=301,L]

# 301 redirects - old blog URLs (with /blog/ prefix) to flat format
RewriteRule ^blog/(.+)$ https://www.roundwoodsolutions.co.uk/blog-$1 [R=301,L]

# Serve .html files for clean URLs
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+)$ $1.html [L]
