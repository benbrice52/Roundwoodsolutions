RewriteEngine On

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Force www
RewriteCond %{HTTP_HOST} !^www\. [NC]
RewriteRule ^(.*)$ https://www.%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Remove trailing slashes (except root)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)/$ /$1 [L,R=301]

# 301 redirects - old Fasthosts builder URLs
Redirect 301 /landscaping https://www.roundwoodsolutions.co.uk/commercial-landscaping-kent
Redirect 301 /learning-and-play https://www.roundwoodsolutions.co.uk/school-grounds-playground-services
Redirect 301 /grounds-maintenance https://www.roundwoodsolutions.co.uk/grounds-maintenance-kent-commercial-property-maintenance
Redirect 301 /contact https://www.roundwoodsolutions.co.uk/contact-us
Redirect 301 /about https://www.roundwoodsolutions.co.uk/about-us

# 301 redirects - old blog URLs
Redirect 301 /blog/commercial-hard-landscaping-kent-a-guide-for-business-property-owners https://www.roundwoodsolutions.co.uk/blog/commercial-hard-landscaping-kent-guide-for-business-owners
Redirect 301 /blog/corporate-landscape-maintenance-kent-business-parks-commercial-properties https://www.roundwoodsolutions.co.uk/blog/corporate-landscape-maintenance-kent-complete-guide-for-business-parks-commercial-properties-2026

# Blog post URL rewrites
RewriteRule ^blog/commercial-hard-landscaping-kent-guide-for-business-owners$ /blog-commercial-hard-landscaping-kent-guide-for-business-owners.html [L]
RewriteRule ^blog/corporate-landscape-maintenance-kent-what-to-look-for-in-a-contractor$ /blog-corporate-landscape-maintenance-kent-what-to-look-for-in-a-contractor.html [L]
RewriteRule ^blog/corporate-landscape-maintenance-kent-complete-guide-for-business-parks-commercial-properties-2026$ /blog-corporate-landscape-maintenance-kent-complete-guide-for-business-parks-commercial-properties-2026.html [L]
RewriteRule ^blog/professional-ground-maintenance-services-in-kent-what-to-expect-in-2026$ /blog-professional-ground-maintenance-services-in-kent-what-to-expect-in-2026.html [L]
RewriteRule ^blog/transforming-school-grounds-sand-pit-and-play-area-installation-in-chatham$ /blog-transforming-school-grounds-sand-pit-and-play-area-installation-in-chatham.html [L]
RewriteRule ^blog/why-january-is-the-perfect-time-to-plan-your-commercial-grounds-maintenance-for-2026$ /blog-why-january-is-the-perfect-time-to-plan-your-commercial-grounds-maintenance-for-2026.html [L]
RewriteRule ^blog/grounds-maintenance-for-business-parks-kent$ /blog-grounds-maintenance-for-business-parks-kent.html [L]

# Serve .html files for clean URLs
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+)$ $1.html [L]
